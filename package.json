{
  "name": "lucasapp-cli",
  "version": "0.1.0",
  "description": "LucasApp CLI - Financial data management for AI agents",
  "author": "StevenACZ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StevenACZ/lucas-cli"
  },
  "homepage": "https://lucas.stevenacz.com/cli",
  "type": "module",
  "bin": {
    "lucas": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "lucasapp",
    "finance",
    "cli",
    "ai-agents"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
